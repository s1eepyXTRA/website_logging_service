# ============================================================
# Dockerfile для генератора событий (Python)
# ============================================================

# Базовый образ — легковесный Python 3.12
FROM python:3.12-slim

# Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# Копируем файл зависимостей отдельно,
# чтобы Docker кэшировал слой с установленными пакетами
COPY requirements.txt .

# Устанавливаем Python-зависимости
RUN pip install --no-cache-dir -r requirements.txt

# Копируем исходный код генератора и базу товаров
COPY generator.py .
COPY products_db.json .

# Запускаем генератор при старте контейнера
CMD ["python", "-u", "generator.py"]
