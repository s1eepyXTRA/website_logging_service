# ============================================================
# Переменные окружения для docker-compose
# ============================================================
# Скопируйте этот файл в .env и измените значения:
#   cp .env.example .env

# Генератор
BASE_RATE=5          # Количество событий в секунду
SCENARIO=normal      # Сценарий: normal / peak / anomaly

# Superset
SUPERSET_SECRET_KEY=supersecret_key_change_in_production  # ОБЯЗАТЕЛЬНО сменить!
